# ============================================
# POLYMARKET TELEGRAM BOT - CONFIGURATION
# ============================================
# Copy this file to .env and fill in your values

# ── MetaMask Wallet ─────────────────────────
# Your MetaMask wallet private key (with 0x prefix)
PRIVATE_KEY=0x_your_private_key_here

# Your MetaMask wallet address
FUNDER_ADDRESS=0x_your_wallet_address_here

# Signature type: 0=EOA/MetaMask
SIGNATURE_TYPE=0

# ── Telegram Bot ────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram user ID (get from @userinfobot)
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Trading Parameters ──────────────────────
# Strategy direction: LONG or SHORT
STRATEGY_DIRECTION=LONG

# Trade sizing: "fixed" or "percent"
TRADE_SIZE_MODE=fixed

# Fixed amount in USDC (used when TRADE_SIZE_MODE=fixed)
TRADE_AMOUNT=5.0

# Portfolio percentage (used when TRADE_SIZE_MODE=percent)
TRADE_PERCENT=5.0

# Take-profit percentage (e.g., 80 = 80% profit)
TAKE_PROFIT_PCT=80.0

# Stop-loss percentage (e.g., 50 = 50% loss)
STOP_LOSS_PCT=50.0

# ── Market Selection ────────────────────────
# Available: 5m, 15m, 1h, 1d
# Comma-separated for multiple markets
MARKET_TIMEFRAMES=15m

# ── Advanced Settings ───────────────────────
# Max slippage in dollars above target price
MAX_SLIPPAGE=0.05

# Target share price for entries
SHARE_PRICE=0.50

# Cooldown in minutes after max progressive entries
COOLDOWN_MINUTES=30

# Max wait time in minutes for right entry price
MAX_ENTRY_WAIT_MINUTES=5

# Tick interval in seconds (how often bot checks)
TICK_INTERVAL=5

# ── Mode ────────────────────────────────────
# Set to "true" to run in paper/simulation mode
PAPER_MODE=false

# Bot auto-restart on errors
AUTO_RESTART=true
